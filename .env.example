# ==================== 运行环境 ====================
# 应用环境：development 允许开发默认密钥；production 强制 JWT_SECRET 至少 32 位。
APP_ENV=development
# standalone 使用 Mock/本地连接器；integrated 用于接入 litemall。
RUNTIME_MODE=standalone
# 当前可用：mock、litemall。使用 litemall 时还必须填写下方 LITEMALL_* 参数。
COMMERCE_ADAPTER=mock

# ==================== 模型与 Embedding ====================
# OpenAI-compatible 服务地址。EMBEDDING_PROVIDER=hash 时不会调用模型服务。
MODEL_BASE_URL=https://api.openai.com/v1
# 使用 OpenAI-compatible Embedding 时必填；hash 模式可留空。
MODEL_API_KEY=
# 预留的对话模型名称；当前 Mock/规则 Agent 查询不会强制调用它。
MODEL_NAME=grok-4.5
# hash 可离线运行；openai 需要 MODEL_API_KEY、MODEL_BASE_URL 和可用模型。
EMBEDDING_PROVIDER=hash
# EMBEDDING_PROVIDER=openai 时使用的 Embedding 模型名。
EMBEDDING_MODEL=text-embedding-3-small
# 必须与 Embedding 模型输出维度及 PostgreSQL vector 列一致。
EMBEDDING_DIMENSIONS=1536

# ==================== 知识入库 ====================
# 是否允许 MarkItDown 插件；生产环境建议保持 false。
MARKITDOWN_ENABLE_PLUGINS=false
# 单次 Markdown/文件上传最大字节数，默认 50 MiB。
MAX_UPLOAD_BYTES=52428800

# ==================== litemall 集成 ====================
# 仅 COMMERCE_ADAPTER=litemall 时生效。Docker 中不要写 127.0.0.1，改用服务名或 host.docker.internal。
LITEMALL_BASE_URL=http://127.0.0.1:8080
# litemall 专用最小权限后台账号；Mock 模式可留空。
LITEMALL_USERNAME=
# litemall 后台密码；Mock 模式可留空，禁止提交真实密码。
LITEMALL_PASSWORD=

# ==================== 状态与基础设施 ====================
# memory 适合开发，重启后审批/审计会丢失；database 适合持久化和 Compose 运行。
STATE_BACKEND=memory
# STATE_BACKEND=database 时必填。SQLite 可写 sqlite+pysqlite:///./data/ecommerce_agent.db。
DATABASE_URL=postgresql+psycopg://agent:agent_dev_password@127.0.0.1:5432/ecommerce_agent
# Celery Worker 的 Redis Broker/Backend；Compose 中主机名应使用 redis。
REDIS_URL=redis://127.0.0.1:6379/0

# ==================== MinIO 对象存储 ====================
# Compose 服务内使用 http://minio:9000；宿主机直连使用 http://127.0.0.1:9000。
MINIO_ENDPOINT=http://127.0.0.1:9000
# MinIO 访问账号；生产环境请替换，不要使用 agent。
MINIO_ACCESS_KEY=agent
# MinIO 访问密钥；生产环境请替换为 Secret。
MINIO_SECRET_KEY=agent_dev_password

# ==================== 鉴权与 Compose 密钥 ====================
# JWT 签名密钥。开发可使用默认值；APP_ENV=production 时必须替换为至少 32 位随机字符串。
JWT_SECRET=development-only-change-me
# PostgreSQL 初始化密码。docker compose 使用；生产环境必须替换。
POSTGRES_PASSWORD=agent_dev_password
# PostgreSQL 初始化用户名，Compose 默认也是 agent。
POSTGRES_USER=agent
# PostgreSQL 初始化数据库名，Compose 默认也是 ecommerce_agent。
POSTGRES_DB=ecommerce_agent
# MinIO 初始化 root 用户，Compose 默认也是 agent。
MINIO_ROOT_USER=agent
# MinIO 初始化 root 密码，生产环境必须替换，并与 MINIO_SECRET_KEY 保持一致或按部署策略区分。
MINIO_ROOT_PASSWORD=agent_dev_password
